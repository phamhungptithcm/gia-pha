# Copy to scripts/local-release.env (ignored by git) and fill your real values.
# This file is auto-loaded by scripts/build_mobile_release_local.sh.

# Optional profile hint for local runs: production | staging | env
BEFAM_RELEASE_PROFILE=staging

# Optional compile-time/runtime defaults
BEFAM_ALLOW_BUNDLED_FIREBASE_OPTIONS=true
BEFAM_OTP_PROVIDER=firebase
BEFAM_ENABLE_APP_CHECK=true
BEFAM_FIREBASE_IOS_BUNDLE_ID=com.familyclanapp.befam

# Optional build overrides
# BEFAM_BUILD_NAME=1.0.0
# BEFAM_BUILD_NUMBER=100

# Staging local release builds can keep bundled staging Firebase and will use
# Google test AdMob app IDs/ad units automatically unless you override them.

# Android signing (choose one set)
# 1) Staging-prefixed keys (recommended for local staging release flow)
ANDROID_STAGING_KEYSTORE_BASE64=replace-with-base64-keystore
ANDROID_STAGING_KEYSTORE_PASSWORD=replace-with-keystore-password
ANDROID_STAGING_KEY_ALIAS=replace-with-key-alias
ANDROID_STAGING_KEY_PASSWORD=replace-with-key-password

# 2) Or reuse release-main naming
# ANDROID_RELEASE_KEYSTORE_BASE64=
# ANDROID_RELEASE_KEYSTORE_PASSWORD=
# ANDROID_RELEASE_KEY_ALIAS=
# ANDROID_RELEASE_KEY_PASSWORD=

# iOS signing (choose one set)
# 1) Staging-prefixed keys (recommended for local staging release flow)
IOS_STAGING_P12_BASE64=
IOS_STAGING_P12_PASSWORD=
IOS_STAGING_PROVISIONING_PROFILE_BASE64=
IOS_STAGING_TEAM_ID=

# 2) Or reuse release-main naming
# IOS_P12_BASE64=
# IOS_P12_PASSWORD=
# IOS_PROVISIONING_PROFILE_BASE64=
# IOS_TEAM_ID=

# Optional: explicit export options for iOS IPA build
# BEFAM_IOS_EXPORT_OPTIONS_PLIST=/absolute/path/to/ExportOptions.plist
