# ---------------------------------------------------------------------------
# GitHub Environment "production" variable template
# Source of truth:
# - firebase/functions/src/config/runtime.ts
# - mobile/befam/lib/core/services/app_environment.dart
# - .github/workflows/deploy-firebase.yml
# ---------------------------------------------------------------------------

# Required vars (Functions + billing + OTP)
FIREBASE_PROJECT_ID=be-fam-3ab23
FIREBASE_FUNCTIONS_REGION=asia-southeast1
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_RUNTIME_CONFIG_COLLECTION=runtimeConfig
APP_RUNTIME_CONFIG_DOC_ID=global

EXPIRE_INVITES_JOB_SCHEDULE=0 * * * *
EVENT_REMINDER_JOB_SCHEDULE=*/30 * * * *
EVENT_REMINDER_LOOKAHEAD_MINUTES=43200
EVENT_REMINDER_SCAN_LIMIT=1500
EVENT_REMINDER_GRACE_MINUTES=45

BILLING_SUBSCRIPTION_REMINDER_JOB_SCHEDULE=0 7 * * *
BILLING_PENDING_TIMEOUT_JOB_SCHEDULE=*/5 * * * *
BILLING_DELINQUENCY_JOB_SCHEDULE=0 8 * * *
BILLING_CONTACT_NOTICE_JOB_SCHEDULE=*/10 * * * *
BILLING_PENDING_TIMEOUT_MINUTES=20
BILLING_PENDING_TIMEOUT_LIMIT=800
BILLING_DELINQUENCY_GRACE_DAYS=7
BILLING_DELINQUENCY_LIMIT=800
BILLING_DELINQUENCY_REMINDER_DAYS=7,3,1
BILLING_CONTACT_NOTICE_BATCH_LIMIT=200
BILLING_CONTACT_NOTICE_WEBHOOK_TIMEOUT_MS=6000
BILLING_CONTACT_NOTICE_WEBHOOK_MAX_RETRIES=2
BILLING_CONTACT_NOTICE_WEBHOOK_BACKOFF_MS=300
BILLING_CONTACT_NOTICE_REQUIRE_ENDPOINTS=false

NOTIFICATION_PUSH_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_COLLECTION=mail
NOTIFICATION_DEFAULT_PUSH_ENABLED=true
NOTIFICATION_DEFAULT_EMAIL_ENABLED=false
NOTIFICATION_ALLOW_NON_OTP_SMS=false
NOTIFICATION_EVENT_MAX_AUDIENCE=5000
BILLING_CONTACT_SMS_WEBHOOK_URL=
BILLING_CONTACT_EMAIL_WEBHOOK_URL=

CALLABLE_ENFORCE_APP_CHECK=true
OTP_PROVIDER=twilio
OTP_ALLOWED_DIAL_CODES=84
OTP_TWILIO_VERIFY_SERVICE_SID=
OTP_TWILIO_TIMEOUT_MS=6000
OTP_TWILIO_MAX_RETRIES=2
OTP_TWILIO_BACKOFF_MS=300

GOOGLE_PLAY_PACKAGE_NAME=com.befam.app
BILLING_IAP_ALLOW_TEST_MOCK=false
BILLING_IAP_APPLE_VERIFY_TIMEOUT_MS=5000
BILLING_IAP_APPLE_VERIFY_MAX_RETRIES=2
BILLING_IAP_APPLE_VERIFY_BACKOFF_MS=350
GOOGLE_IAP_RTDN_AUDIENCE=https://asia-southeast1-be-fam-3ab23.cloudfunctions.net/googleIapWebhook
GOOGLE_IAP_RTDN_SERVICE_ACCOUNT_EMAIL=

# Required secrets (Functions + OTP + IAP webhooks)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
BILLING_WEBHOOK_SECRET=replace-with-strong-secret
APPLE_SHARED_SECRET=replace-with-apple-shared-secret
OTP_TWILIO_ACCOUNT_SID=
OTP_TWILIO_AUTH_TOKEN=

# Optional vars (legacy and mobile/web compile-time)
BILLING_ALLOW_MANUAL_SETTLEMENT=false
BILLING_ENABLE_LEGACY_CARD_FLOW=false
BILLING_CARD_CHECKOUT_URL_BASE=
BILLING_PRICING_CACHE_MS=120000

BEFAM_ALLOW_BUNDLED_FIREBASE_OPTIONS=false
BEFAM_FIREBASE_PROJECT_ID=
BEFAM_FIREBASE_STORAGE_BUCKET=
BEFAM_FIREBASE_ANDROID_API_KEY=
BEFAM_FIREBASE_ANDROID_APP_ID=
BEFAM_FIREBASE_ANDROID_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_IOS_API_KEY=
BEFAM_FIREBASE_IOS_APP_ID=
BEFAM_FIREBASE_IOS_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_IOS_BUNDLE_ID=
BEFAM_FIREBASE_WEB_API_KEY=
BEFAM_FIREBASE_WEB_APP_ID=
BEFAM_FIREBASE_WEB_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_WEB_AUTH_DOMAIN=
BEFAM_FIREBASE_WEB_MEASUREMENT_ID=
BEFAM_FIREBASE_FUNCTIONS_REGION=
BEFAM_DEFAULT_TIMEZONE=
BEFAM_ENABLE_APP_CHECK=true
BEFAM_APP_CHECK_WEB_RECAPTCHA_SITE_KEY=
BEFAM_INVALID_CHECKOUT_HOSTS=example.com
BEFAM_ALLOW_FIREBASE_PHONE_FALLBACK=false
BEFAM_BILLING_PENDING_TIMEOUT_MINUTES=20

# Optional secrets
CARD_WEBHOOK_SECRET=
BILLING_CONTACT_NOTICE_WEBHOOK_TOKEN=
APPLE_IAP_WEBHOOK_BEARER_TOKEN=
GOOGLE_IAP_WEBHOOK_BEARER_TOKEN=

# Release signing secrets (required by release-main workflow)
ANDROID_RELEASE_KEYSTORE_BASE64=
ANDROID_RELEASE_KEYSTORE_PASSWORD=
ANDROID_RELEASE_KEY_ALIAS=
ANDROID_RELEASE_KEY_PASSWORD=
IOS_P12_BASE64=
IOS_P12_PASSWORD=
IOS_PROVISIONING_PROFILE_BASE64=
IOS_TEAM_ID=
