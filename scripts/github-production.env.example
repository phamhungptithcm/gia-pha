ANDROID_RELEASE_KEYSTORE_
ANDROID_RELEASE_KEYSTORE_PASSWORD=Hpmonk22011997X@
ANDROID_RELEASE_KEY_ALIAS=befam_prod
ANDROID_RELEASE_KEY_PASSWORD=Hpmonk22011997X@
IOS_P12_BASE64=
IOS_P12_PASSWORD=
