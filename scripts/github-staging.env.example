# ---------------------------------------------------------------------------
# GitHub Environment "staging" variable template
# Source of truth:
# - firebase/functions/src/config/runtime.ts
# - mobile/befam/lib/core/services/app_environment.dart
# - .github/workflows/deploy-staging.yml
# ---------------------------------------------------------------------------

# Required vars (staging runtime)
FIREBASE_PROJECT_ID=be-fam-3ab23
STAGING_FIREBASE_PROJECT_ID=be-fam-3ab23
FIREBASE_FUNCTIONS_REGION=asia-southeast1
FIRESTORE_DATABASE_ID=(default)
APP_TIMEZONE=Asia/Ho_Chi_Minh
OTP_PROVIDER=firebase
OTP_ALLOWED_DIAL_CODES=84
# Firebase test phone numbers on a real project are capped at 10 entries.
# For larger OTP account matrices in staging, use real SMS delivery or Twilio.

# IAP + store verification (staging)
# If staging uses the same store package as production internal testing:
# GOOGLE_PLAY_PACKAGE_NAME=com.familyclanapp.befam
# If staging uses a dedicated package/app id, set that value instead.
GOOGLE_PLAY_PACKAGE_NAME=com.familyclanapp.befam
BILLING_IAP_ALLOW_TEST_MOCK=false
BILLING_IAP_APPLE_VERIFY_TIMEOUT_MS=5000
BILLING_IAP_APPLE_VERIFY_MAX_RETRIES=2
BILLING_IAP_APPLE_VERIFY_BACKOFF_MS=350
GOOGLE_IAP_RTDN_AUDIENCE=https://asia-southeast1-be-fam-3ab23.cloudfunctions.net/googleIapWebhook
GOOGLE_IAP_RTDN_SERVICE_ACCOUNT_EMAIL=

# Optional app compile-time vars for staging web/mobile builds
BEFAM_ALLOW_BUNDLED_FIREBASE_OPTIONS=false
BEFAM_ENABLE_APP_CHECK=true
BEFAM_OTP_PROVIDER=firebase
BEFAM_WEB_BASE_URL=https://be-fam-3ab23.web.app
BEFAM_FIREBASE_PROJECT_ID=be-fam-3ab23
BEFAM_FIREBASE_STORAGE_BUCKET=
BEFAM_FIREBASE_ANDROID_API_KEY=
BEFAM_FIREBASE_ANDROID_APP_ID=
BEFAM_FIREBASE_ANDROID_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_IOS_API_KEY=
BEFAM_FIREBASE_IOS_APP_ID=
BEFAM_FIREBASE_IOS_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_IOS_BUNDLE_ID=com.familyclanapp.befam
BEFAM_FIREBASE_WEB_API_KEY=
BEFAM_FIREBASE_WEB_APP_ID=
BEFAM_FIREBASE_WEB_MESSAGING_SENDER_ID=
BEFAM_FIREBASE_WEB_AUTH_DOMAIN=
BEFAM_FIREBASE_WEB_MEASUREMENT_ID=
BEFAM_FIREBASE_FUNCTIONS_REGION=asia-southeast1
BEFAM_DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
BEFAM_INVALID_CHECKOUT_HOSTS=example.com
BEFAM_ALLOW_FIREBASE_PHONE_FALLBACK=false
BEFAM_BILLING_PENDING_TIMEOUT_MINUTES=20
BEFAM_IOS_APP_STORE_URL=https://apps.apple.com/app/id<your_app_id>
BEFAM_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.familyclanapp.befam

# Required secrets (choose one auth mode)
# OIDC mode (recommended):
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/<project-number>/locations/global/workloadIdentityPools/<pool-id>/providers/<provider-id>
GCP_SERVICE_ACCOUNT_EMAIL=<deployer-sa>@be-fam-3ab23.iam.gserviceaccount.com
# Fallback key mode:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Runtime secrets
BILLING_WEBHOOK_SECRET=replace-with-strong-secret
APPLE_SHARED_SECRET=replace-with-apple-shared-secret

# Optional secrets
CARD_WEBHOOK_SECRET=replace-with-optional-card-webhook-secret
APPLE_IAP_WEBHOOK_BEARER_TOKEN=replace-with-apple-webhook-token
GOOGLE_IAP_WEBHOOK_BEARER_TOKEN=replace-with-google-webhook-token

# Optional secrets for manual staging mobile release workflow
# (.github/workflows/release-staging.yml)
# You can either configure these IOS/ANDROID_STAGING_* keys, or reuse the
# existing ANDROID_RELEASE_* / IOS_* key names in the staging environment.
ANDROID_STAGING_KEYSTORE_BASE64=
ANDROID_STAGING_KEYSTORE_PASSWORD=
ANDROID_STAGING_KEY_ALIAS=
ANDROID_STAGING_KEY_PASSWORD=
IOS_STAGING_P12_BASE64=
IOS_STAGING_P12_PASSWORD=
IOS_STAGING_PROVISIONING_PROFILE_BASE64=
IOS_STAGING_TEAM_ID=
