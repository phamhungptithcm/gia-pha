{
  "ads_enabled": true,
  "ads_policy_version": "v1",
  "banner_enabled": true,
  "banner_screen_allowlist": "home,tree,events",
  "interstitial_enabled": true,
  "interstitial_breakpoint_allowlist": "shell_tab_switch,route_return,task_complete,result_exit,content_unit_end",
  "ads_new_user_grace_sessions": 2,
  "ads_new_user_grace_days": 1,
  "interstitial_min_session_age_sec": 75,
  "interstitial_min_actions": 3,
  "interstitial_min_interval_sec": 120,
  "interstitial_min_screen_transitions": 2,
  "interstitial_max_per_session": 1,
  "interstitial_max_per_day": 3,
  "interstitial_fail_backoff_sec": 300,
  "important_action_suppress_sec": 45,
  "post_crash_suppress_sessions": 1,
  "rewarded_enabled": true,
  "rewarded_discovery_enabled": true,
  "rewarded_discovery_free_searches_per_session": 3,
  "rewarded_discovery_max_unlocks_per_session": 1,
  "rewarded_discovery_extra_searches_per_reward": 1,
  "app_open_enabled": false,
  "premium_candidate_low_ad_pressure": true,
  "premium_candidate_cooldown_multiplier": 2.0,
  "churn_risk_cooldown_multiplier": 2.0,
  "low_engagement_daily_cap": 1,
  "app_open_min_opens_before_eligible": 5,
  "app_open_min_foreground_gap_sec": 14400,
  "session_exit_after_ad_window_sec": 20
}
