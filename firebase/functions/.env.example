APP_REGION=asia-southeast1
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_RUNTIME_CONFIG_COLLECTION=runtimeConfig
APP_RUNTIME_CONFIG_DOC_ID=global

EXPIRE_INVITES_JOB_SCHEDULE="0 * * * *"
BILLING_SUBSCRIPTION_REMINDER_JOB_SCHEDULE="0 7 * * *"
BILLING_PENDING_TIMEOUT_JOB_SCHEDULE="*/5 * * * *"
BILLING_PENDING_TIMEOUT_MINUTES=20
BILLING_PENDING_TIMEOUT_LIMIT=800
BILLING_ALLOW_MANUAL_SETTLEMENT=false

BILLING_CARD_CHECKOUT_URL_BASE=https://example.com/billing/card
BILLING_VNPAY_FALLBACK_URL=https://example.com/billing/vnpay
BILLING_VNPAY_GATEWAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://example.com/billing/vnpay-return
BILLING_VNPAY_IP_ADDRESS=127.0.0.1
BILLING_VNPAY_LOCALE=vn

BILLING_WEBHOOK_SECRET=replace-with-strong-secret
CARD_WEBHOOK_SECRET=replace-with-strong-secret
VNPAY_TMNCODE=replace-with-vnpay-tmncode
VNPAY_HASH_SECRET=replace-with-vnpay-hash-secret
DEBUG_TOKEN_SIGNER_SERVICE_ACCOUNT=
