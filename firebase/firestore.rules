rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function clanIds() {
      return signedIn() && request.auth.token.clanIds is list
        ? request.auth.token.clanIds
        : [];
    }

    function primaryClanId() {
      return clanIds().size() > 0 && clanIds()[0] is string
        ? clanIds()[0]
        : '';
    }

    function hasClanAccess(clanId) {
      return signedIn() && clanId is string && clanId in clanIds();
    }

    function memberIdClaim() {
      return signedIn() && request.auth.token.memberId is string
        ? request.auth.token.memberId
        : '';
    }

    function primaryRole() {
      return signedIn() && request.auth.token.primaryRole is string
        ? request.auth.token.primaryRole
        : '';
    }

    function branchIdClaim() {
      return signedIn() && request.auth.token.branchId is string
        ? request.auth.token.branchId
        : '';
    }

    function memberAccessModeClaim() {
      return signedIn() && request.auth.token.memberAccessMode is string
        ? request.auth.token.memberAccessMode
        : 'unlinked';
    }

    function isClanAdmin() {
      return primaryRole() in [
        'SUPER_ADMIN',
        'CLAN_ADMIN',
        'CLAN_OWNER',
        'CLAN_LEADER',
        'BRANCH_ADMIN',
        'ADMIN_SUPPORT'
      ];
    }

    function isBillingAdmin() {
      return primaryRole() in [
        'SUPER_ADMIN',
        'CLAN_ADMIN',
        'BRANCH_ADMIN',
        'CLAN_OWNER',
        'CLAN_LEADER',
        'VICE_LEADER',
        'SUPPORTER_OF_LEADER'
      ];
    }

    function canReadBillingDoc(clanId) {
      return memberAccessModeClaim() == 'claimed' &&
        hasClanAccess(clanId) &&
        isBillingAdmin();
    }

    function isClanSettingsAdmin() {
      return primaryRole() in [
        'SUPER_ADMIN',
        'CLAN_ADMIN',
        'CLAN_OWNER',
        'CLAN_LEADER',
        'ADMIN_SUPPORT'
      ];
    }

    function isBranchAdmin() {
      return primaryRole() == 'BRANCH_ADMIN';
    }

    function isScholarshipCouncilHead() {
      return primaryRole() == 'SCHOLARSHIP_COUNCIL_HEAD';
    }

    function isScholarshipReviewerOrAdmin() {
      return isClanAdmin() || isScholarshipCouncilHead();
    }

    function isFinanceViewer() {
      return primaryRole() in ['SUPER_ADMIN', 'CLAN_ADMIN', 'BRANCH_ADMIN', 'TREASURER'];
    }

    function isFinanceManager() {
      return primaryRole() in ['SUPER_ADMIN', 'CLAN_ADMIN', 'TREASURER'];
    }

    function isGovernanceJoinReviewer() {
      return primaryRole() in [
        'SUPER_ADMIN',
        'CLAN_ADMIN',
        'BRANCH_ADMIN',
        'ADMIN_SUPPORT',
        'CLAN_LEADER',
        'VICE_LEADER',
        'SUPPORTER_OF_LEADER'
      ];
    }

    function isBranchScopedMemberManager(existingBranchId, nextBranchId) {
      return isBranchAdmin() &&
        existingBranchId is string &&
        nextBranchId is string &&
        existingBranchId == branchIdClaim() &&
        nextBranchId == existingBranchId;
    }

    function isSelfMember(memberData) {
      return signedIn() && memberData.authUid == request.auth.uid;
    }

    function safeProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fullName',
        'normalizedFullName',
        'nickName',
        'birthDate',
        'deathDate',
        'phoneE164',
        'email',
        'addressText',
        'jobTitle',
        'avatarUrl',
        'bio',
        'socialLinks',
        'updatedAt',
        'updatedBy'
      ]);
    }

    function validUserProfileWrite(userId) {
      return signedIn() &&
        userId == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'uid',
          'memberId',
          'clanId',
          'clanIds',
          'branchId',
          'primaryRole',
          'accessMode',
          'linkedAuthUid',
          'updatedAt',
          'createdAt'
        ]) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.memberId is string &&
        request.resource.data.clanId is string &&
        request.resource.data.clanIds is list &&
        request.resource.data.branchId is string &&
        request.resource.data.primaryRole is string &&
        request.resource.data.accessMode is string &&
        request.resource.data.linkedAuthUid is bool &&
        request.resource.data.memberId == memberIdClaim() &&
        request.resource.data.clanId == primaryClanId() &&
        request.resource.data.clanIds == clanIds() &&
        request.resource.data.branchId == branchIdClaim() &&
        request.resource.data.primaryRole == primaryRole() &&
        request.resource.data.accessMode == memberAccessModeClaim();
    }

    function validDeviceTokenWrite(userId) {
      return signedIn() &&
        userId == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'token',
          'uid',
          'platform',
          'memberId',
          'clanId',
          'branchId',
          'primaryRole',
          'accessMode',
          'updatedAt',
          'createdAt',
          'lastSeenAt'
        ]) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.token is string &&
        request.resource.data.platform is string &&
        request.resource.data.memberId is string &&
        request.resource.data.clanId is string &&
        request.resource.data.branchId is string &&
        request.resource.data.primaryRole is string &&
        request.resource.data.accessMode is string &&
        request.resource.data.memberId == memberIdClaim() &&
        request.resource.data.clanId == primaryClanId() &&
        request.resource.data.branchId == branchIdClaim() &&
        request.resource.data.primaryRole == primaryRole() &&
        request.resource.data.accessMode == memberAccessModeClaim();
    }

    function validNotificationPreferenceWrite(userId, preferenceId) {
      return signedIn() &&
        userId == request.auth.uid &&
        preferenceId == 'notifications' &&
        request.resource.data.keys().hasOnly([
          'id',
          'uid',
          'memberId',
          'clanId',
          'branchId',
          'eventReminders',
          'scholarshipUpdates',
          'fundTransactions',
          'systemNotices',
          'quietHoursEnabled',
          'updatedBy',
          'updatedAt',
          'createdAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'id',
          'uid',
          'memberId',
          'clanId',
          'branchId',
          'eventReminders',
          'scholarshipUpdates',
          'fundTransactions',
          'systemNotices',
          'quietHoursEnabled',
          'updatedBy',
          'updatedAt',
          'createdAt'
        ]) &&
        request.resource.data.id == preferenceId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.memberId is string &&
        request.resource.data.clanId is string &&
        request.resource.data.branchId is string &&
        request.resource.data.memberId == memberIdClaim() &&
        request.resource.data.clanId == primaryClanId() &&
        request.resource.data.branchId == branchIdClaim() &&
        request.resource.data.eventReminders is bool &&
        request.resource.data.scholarshipUpdates is bool &&
        request.resource.data.fundTransactions is bool &&
        request.resource.data.systemNotices is bool &&
        request.resource.data.quietHoursEnabled is bool &&
        request.resource.data.updatedBy == request.auth.uid;
    }

    function relationshipMemberDoc(memberId) {
      return get(/databases/$(database)/documents/members/$(memberId)).data;
    }

    function relationshipMembersResolvable() {
      return request.resource.data.personA is string &&
        request.resource.data.personB is string &&
        exists(
          /databases/$(database)/documents/members/$(request.resource.data.personA)
        ) &&
        exists(
          /databases/$(database)/documents/members/$(request.resource.data.personB)
        );
    }

    function branchScopedRelationshipWrite() {
      return isBranchAdmin() &&
        request.resource.data.clanId is string &&
        hasClanAccess(request.resource.data.clanId) &&
        relationshipMembersResolvable() &&
        relationshipMemberDoc(request.resource.data.personA).clanId ==
          request.resource.data.clanId &&
        relationshipMemberDoc(request.resource.data.personB).clanId ==
          request.resource.data.clanId &&
        relationshipMemberDoc(request.resource.data.personA).branchId ==
          branchIdClaim() &&
        relationshipMemberDoc(request.resource.data.personB).branchId ==
          branchIdClaim();
    }

    match /users/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update: if validUserProfileWrite(userId);
      allow delete: if false;

      match /deviceTokens/{tokenId} {
        allow read: if signedIn() && userId == request.auth.uid;
        allow create, update: if validDeviceTokenWrite(userId);
        allow delete: if signedIn() && userId == request.auth.uid;
      }

      match /preferences/{preferenceId} {
        allow read: if
          signedIn() &&
          userId == request.auth.uid &&
          preferenceId == 'notifications';
        allow create, update: if
          validNotificationPreferenceWrite(userId, preferenceId);
        allow delete: if false;
      }
    }

    match /debug_login_profiles/{phoneE164} {
      allow read, write: if false;
    }

    match /clans/{clanId} {
      allow read: if hasClanAccess(clanId);
      allow create, update: if
        isClanSettingsAdmin() &&
        hasClanAccess(clanId) &&
        request.resource.data.id == clanId;
      allow delete: if false;
    }

    match /branches/{branchId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow create, update: if
        isClanAdmin() &&
        hasClanAccess(request.resource.data.clanId) &&
        request.resource.data.id == branchId;
      allow delete: if false;
    }

    match /members/{memberId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow create: if false;
      allow update: if hasClanAccess(resource.data.clanId) && (
        (
          isClanSettingsAdmin() &&
          request.resource.data.clanId == resource.data.clanId
        ) ||
        isBranchScopedMemberManager(
          resource.data.branchId,
          request.resource.data.branchId
        ) ||
        (
          isSelfMember(resource.data) &&
          safeProfileUpdate() &&
          request.resource.data.clanId == resource.data.clanId &&
          request.resource.data.branchId == resource.data.branchId &&
          request.resource.data.primaryRole == resource.data.primaryRole &&
          request.resource.data.authUid == resource.data.authUid
        )
      );
      allow delete: if false;
    }

    match /relationships/{relationshipId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow create, update: if
        request.resource.data.id == relationshipId &&
        (
          (
            isClanSettingsAdmin() &&
            hasClanAccess(request.resource.data.clanId)
          ) ||
          branchScopedRelationshipWrite()
        );
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow write: if isClanAdmin() && hasClanAccess(request.resource.data.clanId);
    }

    match /funds/{fundId} {
      allow read: if hasClanAccess(resource.data.clanId) && isFinanceViewer();
      allow write: if isFinanceManager() && hasClanAccess(request.resource.data.clanId);
    }

    match /transactions/{transactionId} {
      allow read: if hasClanAccess(resource.data.clanId) && isFinanceViewer();
      allow write: if false;
    }

    match /scholarshipPrograms/{programId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow write: if isClanAdmin() && hasClanAccess(request.resource.data.clanId);
    }

    match /awardLevels/{awardLevelId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow write: if isClanAdmin() && hasClanAccess(request.resource.data.clanId);
    }

    match /achievementSubmissions/{submissionId} {
      allow read: if
        hasClanAccess(resource.data.clanId) &&
        (
          resource.data.memberId == memberIdClaim() ||
          isScholarshipReviewerOrAdmin()
        );
      allow create: if
        hasClanAccess(request.resource.data.clanId) &&
        request.resource.data.memberId == memberIdClaim();
      allow update: if
        hasClanAccess(resource.data.clanId) &&
        resource.data.memberId == memberIdClaim() &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'pending';
      allow delete: if false;
    }

    match /scholarshipApprovalLogs/{logId} {
      allow read: if
        hasClanAccess(resource.data.clanId) &&
        (isClanSettingsAdmin() || isScholarshipCouncilHead());
      allow write: if false;
    }

    match /governanceRoleAssignments/{assignmentId} {
      allow read: if hasClanAccess(resource.data.clanId) && isClanSettingsAdmin();
      allow write: if false;
    }

    match /genealogyDiscoveryIndex/{entryId} {
      allow read: if
        signedIn() &&
        (
          resource.data.isPublic == true ||
          (
            hasClanAccess(resource.data.clanId) &&
            isGovernanceJoinReviewer()
          )
        );
      allow write: if false;
    }

    match /joinRequests/{requestId} {
      allow read: if hasClanAccess(resource.data.clanId) && isGovernanceJoinReviewer();
      allow write: if false;
    }

    match /joinRequestNotifications/{notificationId} {
      allow read: if hasClanAccess(resource.data.clanId) && isGovernanceJoinReviewer();
      allow write: if false;
    }

    match /joinRequestNotificationEvents/{eventId} {
      allow read: if hasClanAccess(resource.data.clanId) && isGovernanceJoinReviewer();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if
        hasClanAccess(resource.data.clanId) &&
        (resource.data.memberId == memberIdClaim() || isClanAdmin());
      allow update: if
        hasClanAccess(resource.data.clanId) &&
        resource.data.memberId == memberIdClaim() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRead'
        ]);
      allow create, delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if isClanAdmin() && hasClanAccess(resource.data.clanId);
      allow write: if isClanAdmin() && hasClanAccess(request.resource.data.clanId);
    }

    match /memberSearchIndex/{docId} {
      allow read: if hasClanAccess(resource.data.clanId);
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isClanAdmin() && hasClanAccess(resource.data.clanId);
      allow write: if false;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if canReadBillingDoc(resource.data.clanId);
      allow write: if false;
    }

    match /billingSettings/{settingsId} {
      allow read: if canReadBillingDoc(resource.data.clanId);
      allow write: if false;
    }

    match /paymentTransactions/{transactionId} {
      allow read: if canReadBillingDoc(resource.data.clanId);
      allow write: if false;
    }

    match /subscriptionInvoices/{invoiceId} {
      allow read: if canReadBillingDoc(resource.data.clanId);
      allow write: if false;
    }

    match /billingAuditLogs/{auditLogId} {
      allow read: if canReadBillingDoc(resource.data.clanId);
      allow write: if false;
    }

    match /paymentWebhookEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
