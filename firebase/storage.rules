rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function clanIds() {
      return signedIn() && request.auth.token.clanIds is list
        ? request.auth.token.clanIds
        : [];
    }

    function hasUserDoc() {
      return signedIn() &&
        exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userClanIds() {
      return hasUserDoc() &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.clanIds is list
        ? get(/databases/(default)/documents/users/$(request.auth.uid)).data.clanIds
        : [];
    }

    function hasClanAccess(clanId) {
      return signedIn() && (
        clanId in clanIds() ||
        clanId in userClanIds()
      );
    }

    function memberIdClaim() {
      return signedIn() && request.auth.token.memberId is string
        ? request.auth.token.memberId
        : hasUserDoc() &&
          get(/databases/(default)/documents/users/$(request.auth.uid)).data.memberId is string
        ? get(/databases/(default)/documents/users/$(request.auth.uid)).data.memberId
        : '';
    }

    function primaryRole() {
      return signedIn() && request.auth.token.primaryRole is string
        ? request.auth.token.primaryRole
        : hasUserDoc() &&
          get(/databases/(default)/documents/users/$(request.auth.uid)).data.primaryRole is string
        ? get(/databases/(default)/documents/users/$(request.auth.uid)).data.primaryRole
        : '';
    }

    function isClanAdmin() {
      return signedIn() && primaryRole() in [
        'SUPER_ADMIN',
        'CLAN_ADMIN',
        'BRANCH_ADMIN'
      ];
    }

    function isScholarshipCouncilHead() {
      return signedIn() && primaryRole() == 'SCHOLARSHIP_COUNCIL_HEAD';
    }

    function isScholarshipReviewerOrAdmin() {
      return isClanAdmin() || isScholarshipCouncilHead();
    }

    function isScholarshipEvidencePath(path) {
      return path is string && path.matches('^scholarship/evidence/.*$');
    }

    function isValidWritePayload(maxBytes) {
      return request.resource == null ||
        (
          request.resource.size < maxBytes &&
          request.resource.contentType is string &&
          request.resource.contentType.size() > 0
        );
    }

    match /clans/{clanId}/members/{memberId}/avatar/{fileName} {
      allow read: if hasClanAccess(clanId);
      allow write: if
        hasClanAccess(clanId) &&
        (isClanAdmin() || memberId == memberIdClaim()) &&
        (
          request.resource == null ||
          (
            request.resource.size < 10 * 1024 * 1024 &&
            request.resource.contentType.matches('image/.*')
          )
        );
    }

    match /clans/{clanId}/{allPaths=**} {
      allow read: if
        hasClanAccess(clanId) &&
        !isScholarshipEvidencePath(allPaths);
      allow write: if
        isClanAdmin() &&
        hasClanAccess(clanId) &&
        !isScholarshipEvidencePath(allPaths) &&
        isValidWritePayload(25 * 1024 * 1024);
    }

    match /clans/{clanId}/scholarship/evidence/{fileName} {
      allow read: if hasClanAccess(clanId) && isScholarshipReviewerOrAdmin();
      allow write: if false;
    }

    match /clans/{clanId}/scholarship/evidence/{memberId}/{fileName} {
      allow read: if
        hasClanAccess(clanId) &&
        (
          memberId == memberIdClaim() ||
          isScholarshipReviewerOrAdmin()
        );
      allow write: if
        hasClanAccess(clanId) &&
        memberId == memberIdClaim() &&
        isValidWritePayload(20 * 1024 * 1024);
    }

    match /submissions/{clanId}/{memberId}/{fileName} {
      allow read: if
        hasClanAccess(clanId) &&
        (
          memberId == memberIdClaim() ||
          isScholarshipReviewerOrAdmin()
        );
      allow write: if
        hasClanAccess(clanId) &&
        memberId == memberIdClaim() &&
        isValidWritePayload(20 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
